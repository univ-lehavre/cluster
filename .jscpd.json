{
  "$schema": "https://raw.githubusercontent.com/kucherenko/jscpd/master/packages/jscpd/schemas/jscpd-config.schema.json",
  "threshold": 5,
  "minTokens": 70,
  "format": ["markdown", "yaml", "shell", "json"],
  "ignore": [
    "**/node_modules/**",
    "**/.git/**",
    "docs/dist/**",
    "docs/.astro/**",
    "docs/src/content/docs/docs/**",
    "pnpm-lock.yaml",
    "CHANGELOG.md",
    "storage/ceph/crds.yaml",
    "storage/ceph/common.yaml",
    "storage/ceph/operator.yaml",
    "storage/ceph/cluster.yaml",
    "storage/ceph/dashboard.yaml",
    "storage/ceph/toolbox.yaml",
    "platform/cert-manager/cert-manager.yaml",
    "platform/argocd/argocd.yaml",
    "platform/kube-prometheus-stack/crds.yaml",
    "platform/kube-prometheus-stack/kube-prometheus-stack.yaml",
    "platform/loki/loki.yaml",
    "platform/loki/promtail.yaml",
    "platform/cloudnative-pg/operator.yaml",
    "platform/cloudnative-pg/plugin-barman-cloud.yaml",
    "platform/dagster/dagster.yaml",
    "platform/marquez/marquez.yaml"
  ],
  "absolute": false,
  "gitignore": true,
  "reporters": ["console"]
}
