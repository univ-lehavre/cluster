# Node
node_modules/

# Python (uv) — environnement local ; uv.lock + pyproject.toml restent versionnés
.venv/
__pycache__/
.ruff_cache/
.pytest_cache/

# macOS
.DS_Store

# Editors
*.swp
*.swo
.vscode/
.idea/
.claude/

# Logs
*.log

# Secrets / env
.env
.env.*
!.env.example
secrets/

# Config locale d'un déploiement réel — NON versionnée (ADR 0023 : le dépôt
# décrit une plateforme d'EXEMPLE ; les spécificités vivent ici). Les modèles
# génériques `*.example.yaml` restent versionnés.
bootstrap/hosts.yaml

# Catalogue de topologies (ADR 0023/0056 ; nommage uniforme ADR 0102) : les
# topologies RÉELLES/locales `topologies/*.yaml` sont NON versionnées ; seuls les
# modèles génériques `*.example.*` (yaml, README…) restent versionnés. Un seul patron :
# le banc Lima est `banc.example.yaml` (versionné) comme tout modèle — plus d'exception.
/topologies/*
!/topologies/*.example.yaml
!/topologies/*.example.*

# topology.yaml (racine) = symlink d'activation vers une topo du catalogue —
# repointé pour activer (`ln -sf topologies/<x>.example.yaml topology.yaml`),
# JAMAIS versionné.
/topology.yaml

# Snapshots etcd rapatriés hors-nœud (etcd-fetch.yaml) — contiennent TOUS les
# Secrets du cluster, ne JAMAIS versionner.
etcd-snapshots/

# Temp
tmp/
*.tmp

# Vagrant test bench (local state + machine-specific inventory + VDI disks)
bench/**/.vagrant/
bench/**/inventory.yaml
bench/**/*.vdi
bench/*.log

# Archives de runs de validation (logs bruts GÉNÉRISÉS, preuves ADR 0023) —
# versionnées par exception à la règle *.log ci-dessus (honnêteté des Runs).
!bench/lima/runs/
!bench/lima/runs/*.log

# Lima test bench (per-run state : configs VM rendues, inventaire, kubeconfig)
bench/**/.work/

# Astro Starlight (generated output + cache, ADR 0089)
docs/dist/
docs/.astro/

# Résidu de cache de l'ancien moteur VitePress (migré vers Astro Starlight)
docs/.vitepress/

# Ansible runtime cache
.ansible/

# ansible-runner (P5, ADR 0063) : private_data_dir = bootstrap/ → runner y crée
# artifacts/ (logs par run) et env/ (cmdline/envvars/extravars RÉUTILISÉS d'un run
# à l'autre). Artefacts locaux, JAMAIS versionnés — et un env/cmdline résiduel
# fausserait les runs suivants (ex. --syntax-check collé pour tous).
bootstrap/artifacts/
bootstrap/env/

# Code source REDCap — logiciel TIERS sous licence propriétaire (REDCap_License.txt),
# JAMAIS redistribuable ni versionnable. Il est STAGÉ par l'opérateur dans le contexte
# de build de l'image maison (`platform/redcap/image/source/redcap/`, cf.
# apps/redcap/README.md) ; l'image `registry:80/redcap` le copie au build node-side.
# Seuls le Dockerfile/manifestes/README génériques restent versionnés (ADR 0023 : on
# garde la brique, on génériese l'instance). `apps/redcap/source/` couvert aussi par
# sécurité (ancien emplacement / scratch).
platform/redcap/image/source/
apps/redcap/source/

# OpenTofu / Terraform — provisioning cloud (ADR 0032). L'état contient des
# identités réelles → JAMAIS versionné (ADR 0023) ; idem les *.tfvars réels
# (le *.tfvars.example générique reste versionné). Le code *.tf et
# .terraform.lock.hcl, eux, SONT versionnés.
.terraform/
*.tfstate
*.tfstate.*
*.tfvars
!*.tfvars.example

# Copie générée de docs/ par migrate_docs_to_astro.py (--content-only, ADR 0089)
docs/src/content/docs/docs/
.coverage
