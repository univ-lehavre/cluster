# Inventaire généré par le banc Lima — NE PAS versionner (artefact de run).
cloud:
  children:
    control:
    workers:
  vars:
    ansible_user: lima
{# Identité de l'instance (ADR 0108) : lie cet inventaire à la topo dont il dérive ; le
   rôle audit-log refuse de muter si l'intention (EXPECTED_STACK_ID) diffère. Commentaires
   Jinja (non émis) : la sortie doit rester byte-identique à write_inventory (lib.sh). #}
    stack_id: {{ stack_id }}
{# Transport dédié (ADR 0108) : une instance sur classe locale s'atteint par limactl. #}
    transport: lima
control:
  hosts:
{% for vm in control_nodes %}    {{ vm }}:
      ansible_host: lima-{{ vm }}
      ansible_ssh_common_args: "-F {{ lima_home }}/.lima/{{ vm }}/ssh.config"
{% endfor %}
workers:
{% if worker_nodes %}  hosts:
{% for vm in worker_nodes %}    {{ vm }}:
      ansible_host: lima-{{ vm }}
      ansible_ssh_common_args: "-F {{ lima_home }}/.lima/{{ vm }}/ssh.config"
{% endfor %}
{% else %}  hosts: {}
{% endif %}
control_host:
  hosts:
    localhost:
      ansible_connection: local
