{
  "name": "cluster",
  "private": true,
  "version": "2.53.2",
  "description": "Kubernetes cluster manifests, playbooks and runbooks",
  "author": {
    "name": "Pierre-Olivier Chasset",
    "email": "pierre-olivier.chasset@univ-lehavre.fr"
  },
  "license": "MIT",
  "packageManager": "pnpm@11.3.0",
  "scripts": {
    "format": "prettier --write \"**/*.{yaml,yml,md,json}\"",
    "format:check": "prettier --check \"**/*.{yaml,yml,md,json}\"",
    "lint:yaml": "yamllint .",
    "lint:shell": "find . -name '*.sh' -not -path './node_modules/*' -not -path './.git/*' -not -path './.venv/*' -print0 | xargs -0 shellcheck",
    "lint:k8s": "git ls-files -z -- '*.yaml' ':!:bootstrap/**' ':!:pnpm-lock.yaml' ':!:pnpm-workspace.yaml' ':!:.yamllint.yaml' ':!:.trivyignore.yaml' ':!:.markdownlint-cli2.yaml' ':!:storage/ceph/crds.yaml' ':!:storage/ceph/common.yaml' ':!:storage/ceph/operator.yaml' ':!:storage/ceph/cluster.yaml' ':!:storage/ceph/dashboard.yaml' ':!:storage/ceph/toolbox.yaml' ':!:platform/k8s-dashboard/values.yaml' ':!:platform/kube-prometheus-stack/values.bench.yaml' ':!:platform/loki/values.bench.yaml' ':!:platform/loki/values.promtail.yaml' ':!:platform/cloudnative-pg/operator.yaml' ':!:platform/cloudnative-pg/plugin-barman-cloud.yaml' ':!:platform/dagster/dagster.yaml' ':!:platform/dagster/values.bench.yaml' ':!:platform/marquez/marquez.yaml' ':!:platform/marquez/values.bench.yaml' ':!:bench/*/inventory.yaml' ':!:docs/architecture/registre-drifts.yaml' ':!:bench/lima/runs-history.yaml' ':!:contract/*.example.yaml' ':!:topologies/*.yaml' | xargs -0 -r kubeconform -strict -ignore-missing-schemas -schema-location default -schema-location 'https://raw.githubusercontent.com/datreeio/CRDs-catalog/main/{{.Group}}/{{.ResourceKind}}_{{.ResourceAPIVersion}}.json'",
    "lint:ansible": "ansible-lint bootstrap/",
    "lint:dup": "jscpd .",
    "lint:python": "uv run ruff check . && uv run ruff format --check .",
    "lint:docs-orphans": "uv run python scripts/check_md_orphans.py",
    "lint:stats": "uv run python scripts/check_gouvernance.py --stats-check",
    "lint:drifts": "uv run python scripts/render_drifts.py --check",
    "lint:contract": "uv run python scripts/check_contract.py",
    "lint:code-location": "uv run python scripts/check_code_location_manifest.py",
    "lint:topology": "uv run python scripts/check_topology.py",
    "lint:topology-drift": "uv run python scripts/topology.py artifact diff -f topologies/socle.example.yaml --kind prod",
    "topology": "uv run python scripts/topology.py",
    "check:gouvernance": "uv run python scripts/check_gouvernance.py",
    "test:shell": "bats bench/unit/",
    "test:python": "uv run python -m unittest discover -s tests",
    "test:python:cov": "uv run coverage run -m unittest discover -s tests && uv run coverage report",
    "lint": "pnpm format:check && pnpm lint:yaml && pnpm lint:shell && pnpm lint:k8s && pnpm lint:ansible && pnpm lint:dup && pnpm lint:python && pnpm lint:docs-orphans && pnpm lint:stats && pnpm lint:drifts && pnpm lint:contract && pnpm lint:code-location && pnpm lint:topology && pnpm lint:topology-drift && pnpm test:shell && pnpm test:python",
    "docs:prepare": "uv run python scripts/migrate_docs_to_astro.py --content-only",
    "docs:dev": "pnpm docs:prepare && astro dev --root docs",
    "docs:build": "pnpm docs:prepare && astro build --root docs",
    "docs:preview": "astro preview --root docs",
    "prepare": "lefthook install"
  },
  "dependencies": {
    "@astrojs/starlight": "^0.40.0",
    "astro": "^6.4.8"
  },
  "devDependencies": {
    "@astrojs/mdx": "^6.0.3",
    "@commitlint/cli": "^21.0.0",
    "@commitlint/config-conventional": "^21.0.0",
    "bats": "^1.13.0",
    "jscpd": "^4.2.4",
    "lefthook": "^2.0.0",
    "prettier": "^3.3.0",
    "starlight-links-validator": "^0.24.1"
  }
}
