{
  "name": "cluster",
  "private": true,
  "version": "2.4.0",
  "description": "Kubernetes cluster manifests, playbooks and runbooks",
  "author": {
    "name": "Pierre-Olivier Chasset",
    "email": "pierre-olivier.chasset@univ-lehavre.fr"
  },
  "license": "MIT",
  "packageManager": "pnpm@11.3.0",
  "scripts": {
    "format": "prettier --write \"**/*.{yaml,yml,md,json}\"",
    "format:check": "prettier --check \"**/*.{yaml,yml,md,json}\"",
    "lint:yaml": "yamllint .",
    "lint:shell": "find . -name '*.sh' -not -path './node_modules/*' -not -path './.git/*' -print0 | xargs -0 shellcheck",
    "lint:k8s": "git ls-files -z -- '*.yaml' ':!:bootstrap/**' ':!:pnpm-lock.yaml' ':!:pnpm-workspace.yaml' ':!:.yamllint.yaml' ':!:.trivyignore.yaml' ':!:storage/ceph/crds.yaml' ':!:storage/ceph/common.yaml' ':!:storage/ceph/operator.yaml' ':!:storage/ceph/cluster.yaml' ':!:storage/ceph/dashboard.yaml' ':!:storage/ceph/toolbox.yaml' ':!:platform/k8s-dashboard/values.yaml' ':!:test/*/inventory.yaml' | xargs -0 -r kubeconform -strict -ignore-missing-schemas -schema-location default -schema-location 'https://raw.githubusercontent.com/datreeio/CRDs-catalog/main/{{.Group}}/{{.ResourceKind}}_{{.ResourceAPIVersion}}.json'",
    "lint:ansible": "ansible-lint bootstrap/",
    "lint:dup": "jscpd .",
    "lint": "pnpm format:check && pnpm lint:yaml && pnpm lint:shell && pnpm lint:dup",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "release": "commit-and-tag-version",
    "release:dry": "commit-and-tag-version --dry-run",
    "prepare": "lefthook install"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.0",
    "@commitlint/config-conventional": "^21.0.0",
    "commit-and-tag-version": "^12.5.0",
    "jscpd": "^4.2.4",
    "lefthook": "^2.0.0",
    "prettier": "^3.3.0",
    "vitepress": "^1.6.4"
  }
}
