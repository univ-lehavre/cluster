{
  "name": "cluster",
  "private": true,
  "version": "2.29.2",
  "description": "Kubernetes cluster manifests, playbooks and runbooks",
  "author": {
    "name": "Pierre-Olivier Chasset",
    "email": "pierre-olivier.chasset@univ-lehavre.fr"
  },
  "license": "MIT",
  "packageManager": "pnpm@11.3.0",
  "scripts": {
    "format": "prettier --write \"**/*.{yaml,yml,md,json}\"",
    "format:check": "prettier --check \"**/*.{yaml,yml,md,json}\"",
    "lint:yaml": "yamllint .",
    "lint:shell": "find . -name '*.sh' -not -path './node_modules/*' -not -path './.git/*' -print0 | xargs -0 shellcheck",
    "lint:k8s": "git ls-files -z -- '*.yaml' ':!:bootstrap/**' ':!:pnpm-lock.yaml' ':!:pnpm-workspace.yaml' ':!:.yamllint.yaml' ':!:.trivyignore.yaml' ':!:.markdownlint-cli2.yaml' ':!:storage/ceph/crds.yaml' ':!:storage/ceph/common.yaml' ':!:storage/ceph/operator.yaml' ':!:storage/ceph/cluster.yaml' ':!:storage/ceph/dashboard.yaml' ':!:storage/ceph/toolbox.yaml' ':!:platform/k8s-dashboard/values.yaml' ':!:platform/kube-prometheus-stack/values.bench.yaml' ':!:platform/loki/values.bench.yaml' ':!:platform/loki/values.promtail.yaml' ':!:platform/cloudnative-pg/operator.yaml' ':!:platform/cloudnative-pg/plugin-barman-cloud.yaml' ':!:platform/dagster/dagster.yaml' ':!:platform/dagster/values.bench.yaml' ':!:platform/marquez/marquez.yaml' ':!:platform/marquez/values.bench.yaml' ':!:test/*/inventory.yaml' | xargs -0 -r kubeconform -strict -ignore-missing-schemas -schema-location default -schema-location 'https://raw.githubusercontent.com/datreeio/CRDs-catalog/main/{{.Group}}/{{.ResourceKind}}_{{.ResourceAPIVersion}}.json'",
    "lint:ansible": "ansible-lint bootstrap/",
    "lint:dup": "jscpd .",
    "lint:python": "uv run ruff check . && uv run ruff format --check .",
    "lint:docs-orphans": "uv run python scripts/check_md_orphans.py",
    "test:shell": "bats test/unit/",
    "test:python": "uv run python -m unittest discover -s tests",
    "lint": "pnpm format:check && pnpm lint:yaml && pnpm lint:shell && pnpm lint:k8s && pnpm lint:ansible && pnpm lint:dup && pnpm lint:python && pnpm lint:docs-orphans && pnpm test:shell && pnpm test:python",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "prepare": "lefthook install"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.0",
    "@commitlint/config-conventional": "^21.0.0",
    "bats": "^1.13.0",
    "jscpd": "^4.2.4",
    "lefthook": "^2.0.0",
    "prettier": "^3.3.0",
    "vitepress": "^1.6.4"
  }
}
