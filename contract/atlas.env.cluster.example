# Contrat cluster → atlas — VARIABLES D'ENVIRONNEMENT (exemple générique)
#
# Patron du fichier que le développeur `atlas` consomme pour se brancher au
# socle. Les VALEURS ici sont des EXEMPLES GÉNÉRIQUES (ADR 0023) ; le vrai
# fichier est GÉNÉRÉ (avec les secrets réels du banc) par :
#
#     nestor access   →   ../atlas/.env.cluster.local  (gitignoré ; ex-access.sh, ADR 0101)
#
# Décision : docs/decisions/0048-acces-local-developpeur.md.
# Source des endpoints : contract/endpoints.example.yaml.
#
# Le code atlas tourne DANS le cluster (pod) : on vise les services par leur NOM
# COURT (`<svc>.<ns>`), PAS le FQDN complet `*.svc.cluster.local` — en prod, un
# search domain externe (resolv.conf, ndots:5) fait timeouter le FQDN complet côté
# gRPC/c-ares et glibc (cf. note DNS de endpoints.example.yaml, drift L58). Depuis
# l'hôte (dev local), les UI sont en L4 NodePort (ADR 0092) : `http://<IP-nœud>:<nodePort>`
# directement en prod (le poste atteint les nœuds), ou via `kubectl port-forward` au
# banc Lima (réseau isolé). Plus de Gateway/hostname ni de forward SSH.

# ── PostgreSQL (CloudNativePG, base pgvector) ────────────────────────────────
POSTGRES_HOST=pg-rw.postgres # nom court (cross-ns) — pas le FQDN (timeout prod)
POSTGRES_PORT=5432
POSTGRES_DB=pgvector
POSTGRES_USER=pgvector
POSTGRES_PASSWORD=pgvector-test-password # exemple ; lu du Secret pg-role-pgvector

# ── Cache partagé des flux (backing service CNPG, base cache — ADR 0093) ──────
# Bloc DÉDIÉ : ne PAS écraser les POSTGRES_* pgvector. L'adaptateur cache atlas
# (derrière readCache/writeCache) construit son DSN postgres depuis ces variables.
POSTGRES_CACHE_HOST=pg-rw.postgres # nom court (cf. note DNS)
POSTGRES_CACHE_PORT=5432
POSTGRES_CACHE_DB=cache
POSTGRES_CACHE_USER=cache
POSTGRES_CACHE_PASSWORD=cache-test-password # exemple ; lu du Secret pg-role-cache

# ── Lineage (OpenLineage → Marquez) ──────────────────────────────────────────
OPENLINEAGE_URL=http://marquez.marquez:5000 # nom court (cf. note DNS)
OPENLINEAGE_ENDPOINT=api/v1/lineage
OPENLINEAGE_NAMESPACE=dagster

# ── Suivi de modèles (MLflow) ────────────────────────────────────────────────
# Pendant de OPENLINEAGE_URL : logguer runs/params/métriques et enregistrer les
# modèles. Backend store = base CNPG `mlflow` ; artefact store = bucket S3 (OBC).
# Chaîne MLOps (maturité 1→2) : le DRIFT (Evidently, à côté de Great Expectations)
# et l'entraînement CONTINU (schedule/sensor Dagster sur transform_job) tracent
# leurs métriques/re-trainings dans MLflow. Evidently lit les parquets du bucket S3
# déjà fourni (backing OBC, cf. AWS_*/BUCKET_* du sync S3) — pas de nouvelle variable.
MLFLOW_TRACKING_URI=http://mlflow.mlflow:5000 # nom court (cf. note DNS)

# ── Registry d'images interne (ADR 0011) ─────────────────────────────────────
REGISTRY=registry:80

# ── Mise en production atlas : push vers la forge Gitea de l'instance ─────────
# CIBLE = le dépôt atlas COMPLET `<org>/atlas` (celui que suit l'`Application` Argo CD :
# `repoURL …/<org>/atlas.git`, `targetRevision: deploy`) — À NE PAS confondre avec le
# dépôt JOUET du socle `<org>/workflows` (`gitea.repo`, seed ; ADR 0111/0086). Le geste
# `dataops/deploy.sh` (ADR atlas 0104) pousse `origin/main` ici ; l'usine in-cluster
# builde et matérialise la branche `deploy` (ADR cluster 0113).
#
# `nestor access` GÉNÈRE cette ligne : user lu du Secret gitea-admin, token API jetable
# dérivé dans le pod (`gitea admin user generate-access-token`), endpoint dérivé de la
# TOPOLOGIE (champ `gitea.push_endpoint` déclaré, sinon déduit de l'exposition : port-forward
# `127.0.0.1:<port>` en réseau isolé, `<access_host>:<nodePort>` sinon). L'exemple ci-dessous
# est la forme LOCALE (port-forward) ; en cloud/baremetal l'hôte:port est celui de l'instance.
GITEA_PUSH_URL=http://atlas-admin:<token>@127.0.0.1:3000/atlas/atlas.git
