{# Configuration kubeadm (ADR 0014) — durcissement du plan de contrôle.
   Remplace l'init en ligne de commande pour pouvoir poser, dès l'init :
     - le chiffrement at-rest des Secrets etcd (EncryptionConfiguration) ;
     - la politique d'audit de l'API server.
   Ces deux réglages ne sont PAS exposés en flags `kubeadm init`.

   Format v1beta4 (kubeadm ≥ 1.31) : `extraArgs` est une LISTE de {name,value}
   (et non plus une map comme en v1beta3). #}
apiVersion: kubeadm.k8s.io/v1beta4
kind: InitConfiguration
# Exposition tout-Cilium (ADR 0020) : Cilium remplace kube-proxy
# (kubeProxyReplacement, datapath eBPF). On NE déploie donc PAS l'addon
# kube-proxy à l'init — c'est plus propre qu'un déploiement suivi d'un retrait
# (pas de fenêtre de coexistence, pas de règles iptables KUBE-* à purger sur un
# cluster neuf). Cilium est armé ensuite par bootstrap/cni.sh.
skipPhases:
  - addon/kube-proxy
{% if control_plane_ip | default('') | length > 0 %}
localAPIEndpoint:
  # Banc multi-node : annoncer l'IP du réseau privé inter-VM (pas le NAT).
  # En prod (control_plane_ip vide), kubeadm détecte l'interface principale.
  advertiseAddress: {{ control_plane_ip }}
  bindPort: {{ control_plane_port }}
{% endif %}
---
apiVersion: kubeadm.k8s.io/v1beta4
kind: ClusterConfiguration
# Nom du cluster (ADR 0053 (b) / 0108) : kubeadm dérive le contexte kubeconfig
# `<user>@{{ cluster_name | default(stack_id | default('cluster-prod')) }}`, au lieu de
# l'homonyme `kubernetes-admin@kubernetes`. Évite qu'un kubeconfig prod écrase un
# kubeconfig banc dans une fusion `KUBECONFIG=banc:prod`.
# On le cale sur le `stack_id` (identité de l'instance, ADR 0108) : le garde d'identité
# du chemin kubectl exige `current-context == stack_id`, et le rewrite du fetch ne renomme
# QUE le défaut kubeadm `kubernetes` — un `clusterName` figé (ex. `cluster-prod`) survivait
# donc au rapatriement et produisait un contexte `…@cluster-prod` ≠ stack → refus du garde.
# `cluster_name` explicite prime (override rare) ; sinon `stack_id` ; sinon fail-safe legacy.
clusterName: {{ cluster_name | default(stack_id | default('cluster-prod')) }}
controlPlaneEndpoint: {{ control_plane_endpoint }}:{{ control_plane_port }}
# Version d'API du control-plane FIGÉE au patch (ADR 0006/0052, #295). Sans
# cette clé, kubeadm résout lui-même la version à l'init → deux installs à deux
# dates dérivent en patchs DIFFÉRENTS. On la cale sur k8s_patch (même source que
# le pin apt de kubeadm dans k8s-install). kubeadm refuse une cible plus récente
# que son binaire : les deux DOIVENT donc dériver de la même variable.
kubernetesVersion: v{{ k8s_patch | default('1.34.9') }}
{% if pod_subnet | default('') | length > 0 or service_subnet | default('') | length > 0 %}
# CIDR pods/services explicites. PROD : non posés (kubeadm garde ses défauts,
# le podCIDR venant de Cilium en 10.244.0.0/16). Utile UNIQUEMENT à une topologie
# multi-cluster fédérée (Cilium Cluster Mesh), qui EXIGE des CIDR DISJOINTS entre
# clusters — sinon le mesh ne monte pas (cf. ADR 0027, spike clustermesh-latency).
networking:
{% if service_subnet | default('') | length > 0 %}
  serviceSubnet: {{ service_subnet }}
{% endif %}
{% if pod_subnet | default('') | length > 0 %}
  podSubnet: {{ pod_subnet }}
{% endif %}
{% endif %}
apiServer:
  extraArgs:
    # Feature gate ImageVolume : requis pour les « image volume extensions »
    # (CloudNativePG ≥ 1.29, voie pgvector sans image custom — cf. ADR 0006/0024).
    # Beta en K8s 1.33+ mais NON activée par défaut → on l'active explicitement.
    - name: feature-gates
      value: ImageVolume=true
    # Chiffrement at-rest des Secrets dans etcd (provider secretbox).
    - name: encryption-provider-config
      value: {{ k8s_enc_dir }}/encryption-config.yaml
    # Politique d'audit + destination + rotation des logs.
    - name: audit-policy-file
      value: {{ k8s_audit_dir }}/audit-policy.yaml
    - name: audit-log-path
      value: {{ k8s_audit_log_dir }}/audit.log
    - name: audit-log-maxage
      value: "30"
    - name: audit-log-maxbackup
      value: "10"
    - name: audit-log-maxsize
      value: "100"
  # Monter les fichiers de config + le répertoire de logs dans le static pod
  # de l'API server (qui tourne en conteneur, donc ne voit pas l'hôte par défaut).
  extraVolumes:
    - name: encryption-config
      hostPath: {{ k8s_enc_dir }}
      mountPath: {{ k8s_enc_dir }}
      readOnly: true
      pathType: DirectoryOrCreate
    - name: audit-policy
      hostPath: {{ k8s_audit_dir }}
      mountPath: {{ k8s_audit_dir }}
      readOnly: true
      pathType: DirectoryOrCreate
    - name: audit-log
      hostPath: {{ k8s_audit_log_dir }}
      mountPath: {{ k8s_audit_log_dir }}
      readOnly: false
      pathType: DirectoryOrCreate
{% if control_plane_vip | default('') | length > 0 %}
  # SAN supplémentaires du certificat de l'API server. EN HA (ha-3cp), la VIP
  # kube-vip (ADR 0047/0055) est un point d'entrée du même API : sans elle dans
  # les certSANs, le TLS casse dès qu'un client tape la VIP au lieu de l'endpoint.
  # VIDE en mono-CP (ADR 0002) → bloc absent, kubeadm garde ses SAN par défaut.
  certSANs:
    - {{ control_plane_vip }}
{% endif %}
# Métriques du plan de contrôle exposées sur 0.0.0.0 (au lieu du défaut kubeadm
# 127.0.0.1) pour que Prometheus (kube-prometheus-stack : kubeScheduler /
# kubeControllerManager / kubeEtcd) puisse les scraper via l'IP du nœud — sinon
# les 3 cibles sont DOWN « connection refused » et déclenchent de fausses alertes
# (audit dirqual 2026-06-24). Le bind reste interne au réseau du/des nœud(s)
# control-plane (pare-feu UFW, ADR sécurité) ; pas d'auth ajoutée ici (métriques).
controllerManager:
  extraArgs:
    - name: bind-address
      value: 0.0.0.0
scheduler:
  extraArgs:
    - name: bind-address
      value: 0.0.0.0
etcd:
  local:
    extraArgs:
      # etcd sert ses métriques sur un port dédié (2381) ; l'exposer sur 0.0.0.0
      # permet le scrape, le port client (2379) restant en TLS mutuel inchangé.
      - name: listen-metrics-urls
        value: http://0.0.0.0:2381
---
# Le kubelet doit AUSSI activer ImageVolume pour monter les volumes d'image
# (le feature gate apiServer seul ne suffit pas — c'est le kubelet qui monte).
apiVersion: kubelet.config.k8s.io/v1beta1
kind: KubeletConfiguration
featureGates:
  ImageVolume: true
