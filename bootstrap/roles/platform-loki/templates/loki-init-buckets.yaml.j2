# Généré par le rôle platform-loki — Job de création des buckets S3 de Loki.
# Endpoint + creds = backing actif (SeaweedFS en banc léger, RGW en prod —
# ADR 0036). Loki n'auto-crée pas ses buckets ; ce Job le fait (idempotent).
apiVersion: batch/v1
kind: Job
metadata:
  name: loki-init-buckets
  namespace: {{ loki_namespace }}
spec:
  backoffLimit: 6
  template:
    metadata:
      labels:
        app: loki-init-buckets
    spec:
      restartPolicy: OnFailure
      securityContext:
        runAsNonRoot: true
        runAsUser: 1000
        seccompProfile:
          type: RuntimeDefault
      containers:
        - name: mb
          image: docker.io/amazon/aws-cli:2.31.21@sha256:ae7057ee66673816887b5964ea5e34663ec1c22d5179b234a4118dbc57dd8911
          env:
            - name: AWS_ACCESS_KEY_ID
              value: '{{ loki_s3_access_key }}'
            - name: AWS_SECRET_ACCESS_KEY
              value: '{{ loki_s3_secret_key }}'
            - name: S3_ENDPOINT
              value: '{{ loki_s3_endpoint }}'
            - name: HOME
              value: /tmp
          command:
            - /bin/sh
            - -c
          args:
            - |
              set -eu
              for b in {{ loki_buckets | join(' ') }}; do
                # Idempotent : OK si mb réussit OU si le bucket existe déjà.
                # Tout autre échec (ex. creds restreints → "make_bucket failed")
                # DOIT faire échouer le Job (drift L39 : l'ancien grep matchait
                # "make_bucket failed" et passait toujours au vert).
                if out="$(aws --endpoint-url "$S3_ENDPOINT" s3 mb "s3://$b" 2>&1)"; then
                  echo "bucket $b créé"
                elif printf '%s' "$out" | grep -q "BucketAlreadyOwnedByYou"; then
                  echo "bucket $b déjà présent"
                else
                  echo "ÉCHEC création bucket $b : $out" >&2
                  exit 1
                fi
              done
              echo "buckets Loki prêts"
          securityContext:
            runAsNonRoot: true
            runAsUser: 1000
            allowPrivilegeEscalation: false
            readOnlyRootFilesystem: true
            capabilities:
              drop:
                - 'ALL'
            seccompProfile:
              type: RuntimeDefault
          volumeMounts:
            - name: tmp
              mountPath: /tmp
      volumes:
        - name: tmp
          emptyDir: {}
