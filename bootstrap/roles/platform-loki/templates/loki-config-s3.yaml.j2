# Généré par le rôle platform-loki — ConfigMap Loki profil S3 (ADR 0036).
# Remplace le ConfigMap `loki` de loki.yaml. endpoint/creds/bucketnames pointent
# le backing S3 actif : SeaweedFS (banc léger, buckets nommés loki-chunks/ruler)
# ou RGW Ceph (prod, bucket UNIQUE de l'OBC pour chunks ET ruler — l'OBC Rook
# n'expose qu'un bucket auto-nommé, drift L38). Seuls ces champs varient vs
# loki.yaml ; le reste de la config est identique.
apiVersion: v1
kind: ConfigMap
metadata:
  name: loki
  namespace: {{ loki_namespace }}
  labels:
    helm.sh/chart: loki-7.0.0
    app.kubernetes.io/name: loki
    app.kubernetes.io/instance: loki
    app.kubernetes.io/version: "3.6.7"
data:
  config.yaml: |

    auth_enabled: false
    bloom_build:
      builder:
        planner_address: ""
      enabled: false
    bloom_gateway:
      client:
        addresses: ""
      enabled: false
    common:
      compactor_grpc_address: 'loki.monitoring.svc.cluster.local:9095'
      path_prefix: /var/loki
      replication_factor: 1
      storage:
        s3:
          access_key_id: {{ loki_s3_access_key }}
          bucketnames: {{ loki_bucket_chunks }}
          endpoint: {{ loki_s3_endpoint }}
          insecure: true
          region: us-east-1
          s3forcepathstyle: true
          secret_access_key: {{ loki_s3_secret_key }}
    compactor:
      delete_request_store: s3
      retention_enabled: true
    frontend:
      scheduler_address: ""
      tail_proxy_url: ""
    frontend_worker:
      scheduler_address: ""
    index_gateway:
      mode: simple
    limits_config:
      max_cache_freshness_per_query: 10m
      query_timeout: 300s
      reject_old_samples: true
      # Rétention dérivée de persistence.mode (ADR 0109) ; full=168h (actuel à l'octet).
      # reject_old_samples_max_age suit retention_period (cohérence : ne pas rejeter des
      # échantillons plus récents que la fenêtre conservée).
      reject_old_samples_max_age: {{ loki_retention_period }}
      retention_period: {{ loki_retention_period }}
      split_queries_by_interval: 15m
      volume_enabled: true
    memberlist:
      join_members:
      - loki-memberlist.monitoring.svc.cluster.local
    pattern_ingester:
      enabled: false
    query_range:
      align_queries_with_step: true
    ruler:
      storage:
        s3:
          access_key_id: {{ loki_s3_access_key }}
          bucketnames: {{ loki_bucket_ruler }}
          endpoint: {{ loki_s3_endpoint }}
          insecure: true
          region: us-east-1
          s3forcepathstyle: true
          secret_access_key: {{ loki_s3_secret_key }}
        type: s3
      wal:
        dir: /var/loki/ruler-wal
    runtime_config:
      file: /etc/loki/runtime-config/runtime-config.yaml
    schema_config:
      configs:
      - from: "2024-04-01"
        index:
          period: 24h
          prefix: index_
        object_store: s3
        schema: v13
        store: tsdb
    server:
      grpc_listen_port: 9095
      http_listen_port: 3100
      http_server_read_timeout: 600s
      http_server_write_timeout: 600s
    storage_config:
      bloom_shipper:
        working_directory: /var/loki/data/bloomshipper
      boltdb_shipper:
        index_gateway_client:
          server_address: ""
      hedging:
        at: 250ms
        max_per_second: 20
        up_to: 3
      tsdb_shipper:
        index_gateway_client:
          server_address: ""
      use_thanos_objstore: false
    tracing:
      enabled: false
