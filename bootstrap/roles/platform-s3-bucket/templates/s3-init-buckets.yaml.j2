# Généré par le rôle platform-s3-bucket — Job de création des buckets S3.
# Backing SeaweedFS (banc léger, ADR 0036) : creds statiques de test. Idempotent.
apiVersion: batch/v1
kind: Job
metadata:
  name: {{ s3b_name }}-init-buckets
  namespace: {{ s3b_namespace }}
spec:
  backoffLimit: 6
  template:
    metadata:
      labels:
        app: {{ s3b_name }}-init-buckets
    spec:
      restartPolicy: OnFailure
      securityContext:
        runAsNonRoot: true
        runAsUser: 1000
        seccompProfile:
          type: RuntimeDefault
      containers:
        - name: mb
          image: {{ s3b_awscli_image }}
          env:
            - name: AWS_ACCESS_KEY_ID
              value: '{{ s3b_access_key }}'
            - name: AWS_SECRET_ACCESS_KEY
              value: '{{ s3b_secret_key }}'
            - name: S3_ENDPOINT
              value: '{{ s3b_endpoint }}'
            - name: HOME
              value: /tmp
          command:
            - /bin/sh
            - -c
          args:
            - |
              set -eu
              for b in {{ s3b_buckets | join(' ') }}; do
                # Idempotent : OK si mb réussit OU si le bucket existe déjà.
                # Tout autre échec DOIT faire échouer le Job (drift L39 : ne pas
                # masquer un "make_bucket failed").
                if out="$(aws --endpoint-url "$S3_ENDPOINT" s3 mb "s3://$b" 2>&1)"; then
                  echo "bucket $b créé"
                elif printf '%s' "$out" | grep -q "BucketAlreadyOwnedByYou"; then
                  echo "bucket $b déjà présent"
                else
                  echo "ÉCHEC création bucket $b : $out" >&2
                  exit 1
                fi
              done
              echo "buckets S3 prêts"
          securityContext:
            runAsNonRoot: true
            runAsUser: 1000
            allowPrivilegeEscalation: false
            readOnlyRootFilesystem: true
            capabilities:
              drop:
                - 'ALL'
            seccompProfile:
              type: RuntimeDefault
          volumeMounts:
            - name: tmp
              mountPath: /tmp
      volumes:
        - name: tmp
          emptyDir: {}
