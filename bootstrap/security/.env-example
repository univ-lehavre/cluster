# Liste des IP des serveurs séparées par des virgules
HOSTS=70.10.113.86,172.142.70.140,30.25.162.163,88.50.113.45
# Adresse courriel à laquelle rediriger les alertes d’un serveur envoyée à root
MAIL_ROOT_REDIRECT=john.doe@example.com
# Utilisateur principal du serveur
HOST_USER=bob
# Durée de vie du mot de passe (en jours) de l’utilisateur principal
PASSWORD_EXPIRATION=42
# Chemin vers votre clé SSH publique locale
PUBLIC_SSH_KEY=~/.ssh/exemple.pub
# (Optionnel) Plage CIDR autorisée à se connecter en SSH, appliquée par UFW
# (tag `ufw`). Si vide, UFW restreint SSH au réseau cluster 10.0.0.0/22
# (cf. ADR 0003 : pas de routage Internet). Mettre p.ex. la plage Tailscale
# (100.64.0.0/10) ou un /24 d'administration pour ouvrir au-delà du cluster.
SSH_ADMIN_CIDR=10.0.0.0/22
